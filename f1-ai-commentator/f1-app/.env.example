# ── Replay poller ─────────────────────────────────────────────────────────────
REPLAY_MODE=true          # true = replay a cached race; false = live OpenF1 (Phase 4)
REPLAY_YEAR=2023
REPLAY_ROUND=6            # Monaco is round 6 in 2023
REPLAY_SESSION=R          # R=Race, Q=Qualifying, FP1/FP2/FP3
REPLAY_TICK_S=2.0         # seconds of wall-clock delay between snapshots

# ── Langflow ──────────────────────────────────────────────────────────────────
LANGFLOW_URL=http://localhost:7860   # or your cloud URL
LANGFLOW_FLOW_ID=                   # paste the UUID from your flow's API tab
LANGFLOW_API_KEY=                   # leave blank if running Langflow locally without auth
LANGFLOW_TIMEOUT_S=30
